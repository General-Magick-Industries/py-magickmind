    </edge>
    <edge source="&quot;EMPLOYER&quot;" target="&quot;EMPLOYEE&quot;">
      <data key="d3">9.0</data>
      <data key="d4">"The Employer is jointly liable with the Employee for wrongful acts committed by the Employee in the course of employment."</data>
