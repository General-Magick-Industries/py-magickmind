      <data key="d5">"liability, contractual terms"</data>
      <data key="d6">chunk-47c412635e02e67c8c5e723ae7e9d0ea</data>
    </edge>
    <edge source="&quot;RECEIVER&quot;" target="&quot;THE COURT&quot;">
