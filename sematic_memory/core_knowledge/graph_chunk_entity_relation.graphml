      <data key="d2">chunk-0e69519b80d6cad28fe98f2e9235bd60</data>
    </node>
    <node id="&quot;SECTION 1438&quot;">
      <data key="d0">"CATEGORY"</data>
      <data key="d1">"Section 1438 specifies that betrothal does not allow an action for enforcing marriage."</data>
      <data key="d2">chunk-32f0865d6629c46fe99f13ae20d441f7</data>
