      <data key="d2">chunk-359c29184e76341f84467fcf371024a6&lt;SEP&gt;chunk-fc29664ee0997602190bcc550d1eddec</data>
    </node>
    <node id="&quot;SECTION 1392&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"A legal provision detailing conditions under which servitude may be relocated within the servient property."</data>
