      <data key="d3">9.0</data>
      <data key="d4">"The Testator must declare their will to the Kromakarn Amphoe, who certifies and records it in compliance with legal requirements."</data>
      <data key="d5">"legal process, documentation"</data>
      <data key="d6">chunk-96ca137e685d301646809ca5adf41812</data>
    </edge>
