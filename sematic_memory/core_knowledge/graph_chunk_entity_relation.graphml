      <data key="d3">7.0</data>
      <data key="d4">"Expenses incurred for the common benefit establish preferential rights over a debtor's entire property."</data>
      <data key="d5">"shared benefit, expense-based rights"</data>
      <data key="d6">chunk-bac2de5ec87beec114bb4549e917cb4e</data>
    </edge>
    <edge source="&quot;FUNERAL EXPENSES&quot;" target="&quot;PREFERENTIAL RIGHTS&quot;">
      <data key="d3">6.0</data>
      <data key="d4">"Funeral expenses generate preferential rights over the debtor's estate in alignment with their social status."</data>
      <data key="d5">"personal expenses, priority payment"</data>
      <data key="d6">chunk-bac2de5ec87beec114bb4549e917cb4e</data>
    </edge>
    <edge source="&quot;TAXES AND DUTIES&quot;" target="&quot;PREFERENTIAL RIGHTS&quot;">
      <data key="d3">8.0</data>
      <data key="d4">"Taxes and duties owed by the debtor hold preferential rights for settlement using the debtor's assets."</data>
      <data key="d5">"public charges, legal priority"</data>
      <data key="d6">chunk-bac2de5ec87beec114bb4549e917cb4e</data>
    </edge>
    <edge source="&quot;DOCUMENT&quot;" target="&quot;DEBTOR&quot;">
      <data key="d3">7.0</data>
      <data key="d4">"The Debtor relies on the Document to prove obligations and transactions related to performance."</data>
      <data key="d5">"legal documentation, proof of obligation"</data>
      <data key="d6">chunk-c35036965b446b68b1f64bc55f989965</data>
    </edge>
    <edge source="&quot;EMPLOYEE ENTITLEMENTS&quot;" target="&quot;PREFERENTIAL RIGHTS&quot;">
      <data key="d3">8.0</data>
      <data key="d4">"Employee wages and related payments are prioritized through preferential rights on the debtor's property."</data>
      <data key="d5">"wage protection, labor rights"</data>
      <data key="d6">chunk-bac2de5ec87beec114bb4549e917cb4e</data>
    </edge>
    <edge source="&quot;SUPPLIES OF DAILY NECESSARIES&quot;" target="&quot;PREFERENTIAL RIGHTS&quot;">
      <data key="d3">5.0</data>
      <data key="d4">"Basic supplies essential for living receive preferential rights over the debtor's assets up to six months."</data>
      <data key="d5">"essential needs, survival finance"</data>
      <data key="d6">chunk-bac2de5ec87beec114bb4549e917cb4e</data>
    </edge>
    <edge source="&quot;MINISTER OF INTERIOR&quot;" target="&quot;REGISTRAR&quot;">
      <data key="d3">7.0</data>
