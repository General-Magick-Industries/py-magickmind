      <data key="d6">chunk-6674ed785a247829af22e22520fa7260</data>
    </edge>
    <edge source="&quot;EMPLOYER&quot;" target="&quot;CONTRACTOR&quot;">
      <data key="d3">15.0</data>
      <data key="d4">"The Employer may not be liable for a wrongful act committed by a Contractor unless negligence in hiring or instructions is proven."&lt;SEP&gt;"The contractor provides work to the employer, and the relationship is defined by mutual obligations under the contract."</data>
      <data key="d5">"contractual liability, negligence"&lt;SEP&gt;"contractual obligations, work delivery"</data>
      <data key="d6">chunk-6674ed785a247829af22e22520fa7260&lt;SEP&gt;chunk-7c177d209afa32287351a7f88d669f7a</data>
    </edge>
