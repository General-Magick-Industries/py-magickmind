      <data key="d3">7.0</data>
      <data key="d4">"The Husband manages his own Sin Suan Tua, as described in the legal guidelines for marital property."</data>
      <data key="d5">"property management, personal assets"</data>
      <data key="d6">chunk-9eea79da373e97e5b9f92916632488ba</data>
    </edge>
