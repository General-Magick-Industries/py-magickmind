      <data key="d2">chunk-e8a12bcf29dd0e194c7a3e4a71523199</data>
    </node>
    <node id="&quot;SECRET SOCIETY&quot;">
      <data key="d0">"CATEGORY"</data>
      <data key="d1">"A secret society is defined as a group whose proceedings are secret and aims are unlawful, subject to legal punishment in Thailand."&lt;SEP&gt;"Secret Society refers to an organization that may be involved in clandestine or illegal activities, often cited in legal contexts."</data>
      <data key="d2">chunk-1429bffff14b8577c8748fc8f14a6678&lt;SEP&gt;chunk-526a0b152c10330561e4c72c14e89416</data>
    </node>
