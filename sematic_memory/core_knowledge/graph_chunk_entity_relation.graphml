      <data key="d3">9.0</data>
      <data key="d4">"Fraud undermines the validity of a juristic act by introducing deception or false information."</data>
      <data key="d5">"deception, legal integrity"</data>
      <data key="d6">chunk-933d505d06605d728d8a7325e6245238</data>
    </edge>
